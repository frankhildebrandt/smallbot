{
  "name": "smallbot",
  "build": {
    "dockerfile": "Dockerfile",
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "ms-vscode.vscode-typescript-next",
      ],
    },
  },
  "privileged": true,
  "securityOpt": ["seccomp=unconfined"],
  "postCreateCommand": "npm install",
}
